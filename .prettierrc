{
    "printWidth": 120,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5",
    "useTabs": false,
    "tabWidth": 4,
    "overrides": [
        {
            "files": ["package.json", "*.json"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}